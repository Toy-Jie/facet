"""Copy high-scoring photos into a "best of" folder.

Copy to ``plugins/copy_to_folder.py`` (drop the ``.example`` suffix) and
adjust ``DEST_DIR``. Every time a photo's aggregate score is above the
configured high-score threshold, the original file is hard-linked into
``DEST_DIR`` preserving its directory structure. Hard-links are used
when the source/destination share a filesystem (cheap, zero extra disk);
copies are used otherwise.

This is the disk-side equivalent of the built-in ``copy_to_folder``
plugin action, but it ships as a real Python plugin so you can extend
the filter logic (e.g. only portraits, only since a given date).
"""

import logging
import os
import shutil
from pathlib import Path

logger = logging.getLogger(__name__)

DEST_DIR = Path(os.environ.get("FACET_BEST_OF_DIR", "/path/to/best-photos"))
# Optional: skip categories you don't want auto-copied.
EXCLUDED_CATEGORIES = {"default"}


def on_high_score(data: dict) -> None:
    src = Path(data.get("path", ""))
    category = data.get("category", "default")
    aggregate = data.get("aggregate", 0.0)

    if not src.exists():
        logger.warning("[copy_to_folder] source missing: %s", src)
        return
    if category in EXCLUDED_CATEGORIES:
        return

    # Preserve "year/month" structure from EXIF date if available, else
    # just dump everything at the top level.
    date_taken = data.get("date_taken", "")
    rel_subdir = ""
    if date_taken and len(date_taken) >= 7:
        rel_subdir = f"{date_taken[:4]}/{date_taken[5:7]}"

    dest_dir = DEST_DIR / rel_subdir
    dest_dir.mkdir(parents=True, exist_ok=True)
    dest_path = dest_dir / src.name

    if dest_path.exists():
        return  # Idempotent — already copied.

    try:
        # Hard-link is fast and shares the underlying inode (no extra
        # disk). Falls back to a full copy if the source and destination
        # live on different filesystems.
        try:
            os.link(src, dest_path)
        except OSError:
            shutil.copy2(src, dest_path)
        logger.info(
            "[copy_to_folder] %s (%.2f) -> %s", src.name, aggregate, dest_path
        )
    except Exception:
        logger.exception("[copy_to_folder] failed for %s", src)
